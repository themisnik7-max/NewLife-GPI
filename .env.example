# Copy to .env / .env.local and fill in real values. Never commit the real
# files — see ARCHITECTURE.md's "Clerk ↔ Supabase Third-Party Auth" section
# for exactly where each Supabase/Clerk value comes from.

# --- Prisma / Postgres (Supabase) — lives in .env ---------------------------
# Project Settings → Database in the Supabase dashboard. DIRECT_URL bypasses
# the connection pooler and is used for migrations; DATABASE_URL is the
# pooled connection the app uses at runtime.
DATABASE_URL="postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# --- Clerk auth — lives in .env.local ---------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Svix signing secret for src/app/api/webhooks/clerk/route.ts, from Clerk
# Dashboard → Webhooks → your endpoint → Signing Secret. NOT set yet.
CLERK_WEBHOOK_SECRET="whsec_..."

# --- Supabase client (Third-Party Auth bridge) — lives in .env.local -------
# Project Settings → API in the Supabase dashboard. NOT set yet — until both
# are set, src/lib/supabaseClient.ts throws at runtime on first use.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# --- BYOK API key encryption — lives in .env ---------------------------------
# AES-256 key for src/lib/data/apiKeys.ts, base64-encoded, must decode to
# exactly 32 bytes. Generate with: openssl rand -base64 32
# NOT set yet — createTenantApiKey()/decrypting a key will throw without it.
# Rotating this value makes every previously-encrypted key undecryptable —
# there is no key-versioning in this schema, so treat it as a one-time,
# durably-stored secret, not something to regenerate casually.
API_KEY_ENCRYPTION_SECRET="base64-encoded-32-byte-key"
